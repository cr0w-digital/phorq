{
    "name": "cr0w/phorq",
    "description": "File-based routing for PHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["router", "file-based", "datastar", "htmx", "sse", "hypermedia"],
    "authors": [
        {
            "name": "Denny Shimkoski",
            "email": "denny@cr0w.digital"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "files": [
            "src/functions/datastar.php",
            "src/functions/global.php",
            "src/functions/phorq.php"
        ],
        "psr-4": {
            "phorq\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
